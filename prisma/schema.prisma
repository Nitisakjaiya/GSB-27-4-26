generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// 1. ตารางพนักงาน (Authentication)
model tb_user {
  user_aid   BigInt   @id @default(autoincrement())
  username   String   @unique @db.VarChar(50)
  password   String   @db.VarChar(255)
  first_name String?  @db.NVarChar(100)
  last_name  String?  @db.NVarChar(100)
  
  // Standard Columns
  created_at DateTime @default(now())
  created_by BigInt?
  updated_at DateTime @default(now()) @updatedAt // 🚀 แก้ไข: เพิ่ม default เพื่อรองรับข้อมูลเดิม
  is_deleted Int      @default(0) @db.TinyInt 
}

// 2. ตารางสัญญาหลัก (Contract Module)
model tb_contract {
  ct_aid           BigInt    @id @default(autoincrement())
  category_code    String?   @db.NVarChar(20)
  ct_number        String?   @db.NVarChar(20)
  ct_date          DateTime? @db.Date
  ct_name          String?   @db.NVarChar(300)
  
  // 🚀 ฟิลด์ใหม่สำหรับแจ้งเตือน Dashboard ตามที่พี่เลี้ยงแนะนำ
  start_date       DateTime? @db.Date
  end_date         DateTime? @db.Date
  
  contract_status  String?   @db.VarChar(20) @default("ACTIVE")
  coordinator_name String?   @db.NVarChar(300)
  sign_date        DateTime? @db.Date
  
  // Relations
  items            tb_contract_items[]

  // Standard Columns
  created_at       DateTime  @default(now())
  created_by       BigInt?
  updated_at       DateTime  @default(now()) @updatedAt // 🚀 แก้ไข: เพิ่ม default
  is_deleted       Int       @default(0) @db.TinyInt

  // Index เพื่อประสิทธิภาพการ Query สัญญาใกล้หมดอายุ
  @@index([end_date])
  @@index([is_deleted])
}

// 3. ตารางรายการย่อย (Contract Items)
model tb_contract_items {
  item_autoid      BigInt    @id @default(autoincrement())
  contract_id      BigInt
  item_type        String?   @db.NVarChar(20) 
  item_agreement   String?   @db.NVarChar(500)
  start_date       DateTime? @db.Date
  end_date         DateTime? @db.Date
  item_cost        Decimal?  @db.Decimal(18, 2)

  // Relation
  contract         tb_contract @relation(fields: [contract_id], references: [ct_aid])

  // Standard Columns
  created_at       DateTime @default(now())
  created_by       BigInt?
  updated_at       DateTime @default(now()) @updatedAt // 🚀 แก้ไข: เพิ่ม default
  is_deleted       Int      @default(0) @db.TinyInt
}

// 4. ตารางคณะกรรมการ (Polymorphic Pattern)
model tb_committees {
  cmit_aid      BigInt  @id @default(autoincrement())
  base_type     String  @db.VarChar(10) // 'CON' หรือ 'PLAN'
  base_id       BigInt
  cmit_name     String? @db.NVarChar(200)
  cmit_position String? @db.NVarChar(100)
  cmit_unit     String? @db.NVarChar(100)

  // Standard Columns
  created_at    DateTime @default(now())
  created_by    BigInt?
  updated_at    DateTime @default(now()) @updatedAt // 🚀 แก้ไข: เพิ่ม default
  is_deleted    Int      @default(0) @db.TinyInt

  @@index([base_type, base_id])
}

// 5. ตารางจัดการไฟล์ (Polymorphic Pattern)
model tb_files {
  file_aid     BigInt   @id @default(autoincrement())
  base_type    String   @db.VarChar(10) 
  base_id      BigInt
  file_name    String   @db.NVarChar(255)
  file_path    String   @db.NVarChar(500) 
  file_size    Int?
  mime_type    String?  @db.VarChar(100)
  
  // Standard Columns
  created_at   DateTime @default(now())
  created_by   BigInt?
  updated_at   DateTime @default(now()) @updatedAt // 🚀 แก้ไข: เพิ่ม default
  is_deleted   Int      @default(0) @db.TinyInt

  @@index([base_type, base_id])
}

// 6. ตารางแผนงานล่วงหน้า (Planning Module)
model tb_planning {
  pl_aid           BigInt    @id @default(autoincrement())
  ref_contract_id  BigInt?   
  pl_number        String?   @db.NVarChar(20)
  pl_name          String?   @db.NVarChar(300)
  pl_year          Int?      
  status           String?   @db.VarChar(20) @default("DRAFT")
  
  // Relations
  items            tb_planning_items[]
  
  // Standard Columns
  created_at       DateTime  @default(now())
  created_by       BigInt?
  updated_at       DateTime  @default(now()) @updatedAt // 🚀 แก้ไข: เพิ่ม default
  is_deleted       Int       @default(0) @db.TinyInt

  @@index([ref_contract_id])
  @@index([is_deleted])
}

// 7. ตารางรายการย่อยของแผนงาน (Planning Items)
model tb_planning_items {
  pli_aid          BigInt    @id @default(autoincrement())
  planning_id      BigInt
  pli_type         String?   @db.NVarChar(20)
  pli_description  String?   @db.NVarChar(500)
  pli_budget       Decimal?  @db.Decimal(18, 2)
  
  // Relation
  planning         tb_planning @relation(fields: [planning_id], references: [pl_aid])

  // Standard Columns
  created_at       DateTime  @default(now())
  created_by       BigInt?
  updated_at       DateTime  @default(now()) @updatedAt // 🚀 แก้ไข: เพิ่ม default
  is_deleted       Int       @default(0) @db.TinyInt
}

// 8. ตารางติดตามความคืบหน้า (Tracking Module - Polymorphic)
model tb_tracking {
  trk_aid          BigInt   @id @default(autoincrement())
  base_type        String   @db.VarChar(10) // 'CON' หรือ 'PLA'
  base_id          BigInt
  trk_status       String?  @db.VarChar(50)
  trk_detail       String?  @db.NVarChar(500)
  trk_date         DateTime @default(now())
  disbursed_amount Decimal? @db.Decimal(18, 2)

  // Standard Columns
  created_at       DateTime @default(now())
  created_by       BigInt?
  updated_at       DateTime @default(now()) @updatedAt
  is_deleted       Int      @default(0) @db.TinyInt

  @@index([base_type, base_id])
}
